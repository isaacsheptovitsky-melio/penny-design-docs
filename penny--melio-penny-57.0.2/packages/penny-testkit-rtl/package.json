{
  "name": "@melio/penny-testkit-rtl",
  "version": "57.0.2",
  "description": "RTL testkits for Penny components",
  "keywords": [
    "penny",
    "testkit",
    "test",
    "rtl",
    "rtl-testkit",
    "react-testing-library"
  ],
  "author": "or.oz <or.oz@melio.com>",
  "license": "UNLICENSED",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "sideEffects": false,
  "publishConfig": {
    "main": "dist/penny-testkit-rtl.js",
    "module": "dist/penny-testkit-rtl.mjs",
    "types": "dist/index.d.ts",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:melio/penny.git",
    "directory": "packages/penny-testkit-rtl"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest -c vite.config.ts --passWithNoTests",
    "lint": "eslint . --cache",
    "build": "vite build",
    "prepack": "dev-scripts prepack",
    "package": "dev-scripts package",
    "postpack": "dev-scripts postpack",
    "analyze": "ANALYZE_BUNDLE=true vite build"
  },
  "peerDependencies": {
    "react": ">=18",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1"
  },
  "devDependencies": {
    "@melio/eslint-config-penny": "workspace:*"
  }
}
