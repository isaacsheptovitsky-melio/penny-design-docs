{
  "version": "independent",
  "npmClient": "pnpm",
  "useWorkspaces": true,
  "command": {
    "version": {
      "exact": true,
      "private": false,
      "allowBranch": "main",
      "message": "chore(release): publish",
      "ignoreChanges": [
        "**/__*__/**",
        "**/test/**",
        "**/*.test.*",
        "**/*.stories.*",
        "**/*.md"
      ]
    }
  }
}
