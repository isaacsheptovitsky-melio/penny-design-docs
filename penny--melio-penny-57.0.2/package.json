{
  "name": "penny",
  "version": "0.0.1",
  "author": "uzi@melio.com",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build-storybook": "pnpm codegen:assets && storybook build --stats-json",
    "publish-storybook": "chromatic --zip --exit-zero-on-changes --exit-once-uploaded --debug --trace-changed expanded --only-changed --untraced \"**/package.json\"",
    "publish-storybook:skip": "chromatic --zip --exit-zero-on-changes --exit-once-uploaded --debug --only-story-files \"packages/penny/src/changelog.mdx\"",
    "test:storybook": "vitest -c .storybook/vitest.config.ts --run",
    "test:a11y": "pnpm test:storybook",
    "prepare": "husky install",
    "precommit": "lerna exec lint-staged --parallel -- --allow-empty --no-stash",
    "typecheck": "lerna run typecheck --parallel --since origin/main",
    "typecheck:ci": "pnpm codegen:assets && lerna exec --parallel -- 'pnpm typecheck | typecheck-junit'",
    "build": "lerna run --stream build --no-private",
    "build:ci": "lerna run package --stream --no-private",
    "test": "lerna run test --stream -- --watch=false",
    "test:ci": "lerna run test:ci --stream --no-private",
    "lint": "lerna run lint --parallel --since origin/main",
    "lint:all": "lerna run lint --parallel",
    "lint:ci": "pnpm codegen:assets && lerna exec --ignore @melio/dev-scripts --parallel -- 'pnpm lint --format=junit --output-file=$INIT_CWD/.reports/$LERNA_PACKAGE_NAME/eslint.xml'",
    "omlet:analyze": "pnpm --filter @melio/penny omlet:analyze",
    "publish:canary": "pnpm build && pnpm changeset publish --tag canary",
    "publish:snapshot": "pnpm build && pnpm changeset publish --tag $DIST_TAG --no-git-tag",
    "version:canary": "pnpm changeset version",
    "version:snapshot": "pnpm changeset version --snapshot $SNAPSHOT_TAG",
    "codegen:assets": "pnpm --filter @melio/penny-assets codegen",
    "upload-assets": "pnpm --filter @melio/penny-assets upload-assets",
    "sync-latest-assets": "pnpm --filter @melio/penny-assets sync-latest-assets",
    "circular-deps:penny": "pnpm -s --filter @melio/penny circular-deps --target src/theme",
    "circular-deps:penny:json": "pnpm -s --filter @melio/penny circular-deps:json --target src/theme --json ../../artifacts/theme-circular.json"
  },
  "pnpm": {
    "overrides": {
      "@typescript-eslint/parser": "^8.49.0",
      "@typescript-eslint/eslint-plugin": "^8.49.0",
      "eslint-plugin-prettier": "^5.5.4",
      "eslint-plugin-vitest": "^0.5.4",
      "ansi-html": "^0.0.8",
      "ansi-regex": "^4.1.1",
      "node-forge": "^1.3.0",
      "glob-parent": "^5.1.2",
      "csstype": "^3.1.0",
      "@types/react": "^18.3.12",
      "@types/react-dom": "^18.3.1",
      "react": "^18.3.1",
      "react-dom": "^18.3.1"
    }
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.698.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-private-methods": "^7.18.6",
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@chakra-ui/react": "^2.10.4",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.29.7",
    "@chromatic-com/storybook": "^4.1.3",
    "@emotion/react": "^11",
    "@emotion/styled": "^11",
    "@eslint/js": "^9.39.1",
    "@faker-js/faker": "^7.6.0",
    "@melio/dev-scripts": "workspace:*",
    "@melio/eslint-config-penny": "workspace:*",
    "@playwright/test": "^1.48.2",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-links": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.0.8",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-istanbul": "^2.1.9",
    "babel-plugin-dynamic-import-node": "^2.3.3",
    "chromatic": "^11.28.2",
    "csstype": "^3.1.0",
    "cypress": "^13.15.0",
    "esbuild": "^0.27.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-junit": "^9.0.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-monorepo": "^0.3.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-vitest": "^0.5.4",
    "framer-motion": "^11.11.17",
    "globals": "^16.5.0",
    "husky": "^8.0.3",
    "jsdom": "^26.0.0",
    "lerna": "^5.4.3",
    "lint-staged": "^15.2.0",
    "lodash": "^4.17.21",
    "madge": "^8.0.0",
    "mime-types": "^3.0.1",
    "mockdate": "^3.0.5",
    "prettier": "^3.7.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "^6",
    "remark-gfm": "^4.0.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-visualizer": "^6.0.5",
    "s3-sync-client": "^4.3.1",
    "storybook": "^10.3.3",
    "storybook-addon-pseudo-states": "^10.3.3",
    "storybook-utils": "workspace:*",
    "ts-morph": "^26.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^3.2.4",
    "vitest-canvas-mock": "^0.3.3"
  },
  "engines": {
    "node": ">=22.19.0",
    "pnpm": ">=10"
  },
  "volta": {
    "node": "22.19.0"
  },
  "packageManager": "pnpm@10.26.0"
}
